}

// ─── Phase 21: Document Intelligence Workbench ───────────────────────────────

enum ExtractionReviewStatus {
  UPLOADED
  QUEUED
  PROCESSING
  NEEDS_REVIEW
  APPROVED
  PROMOTED
  REJECTED
  FAILED
  EXPIRED
}

/// Human-review wrapper around a document extraction AI job.
/// Preserves original AI output and user-corrected output separately.
/// Promotion to business records (invoices/vouchers/vendor bills) creates drafts only.
/// Added: Phase 21 Sprint 21.2
model ExtractionReview {
  id                 String                 @id @default(cuid())
  orgId              String
  aiJobId            String?
  ocrJobId           String?
  sourceAttachmentId String?
  /// "invoice" | "voucher" | "vendor_bill"
  targetType         String?
  targetDraftId      String?
  status             ExtractionReviewStatus @default(UPLOADED)
  originalOutput     Json?
  correctedOutput    Json?
  reviewerId         String?                @db.Uuid
  reviewedAt         DateTime?
  promotedAt         DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  organization Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  fields       ExtractionField[]

  @@index([orgId, status])
  @@index([orgId, createdAt])
  @@map("extraction_review")
}

/// Field-level extracted data with confidence, validation status, and user correction.
/// Added: Phase 21 Sprint 21.2
model ExtractionField {
  id               String   @id @default(cuid())
  reviewId         String
  fieldKey         String
  proposedValue    String?
  normalizedValue  String?
  correctedValue   String?
  confidence       Float?
  /// "valid" | "invalid" | "warning" | "unverified"
  validationStatus String?
  validationError  String?
  sourcePage       Int?
  sourceRegion     String?
  accepted         Boolean  @default(false)
  rejectedReason   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  review ExtractionReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("extraction_field")
}

// ─── Phase 21: Customer Health Intelligence ───────────────────────────────────

/// Periodic or on-demand snapshot of a customer's health score and risk band.
/// Score and factors are computed from payment history, overdue data, arrangements,
/// and disputes. No black-box scoring — all factors are stored with the snapshot.
/// Added: Phase 21 Sprint 21.3
model CustomerHealthSnapshot {
  id                String   @id @default(cuid())
  orgId             String
  customerId        String
  /// 0–100 score (higher = healthier)
  score             Float
  /// "healthy" | "at_risk" | "high_risk" | "critical"
  riskBand          String
  factors           Json
  recommendedAction String?
  calculatedAt      DateTime @default(now())
  validUntil        DateTime

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, customerId, calculatedAt])
  @@index([orgId, riskBand])
  @@map("customer_health_snapshot")
}

// ─── Phase 21: Anomaly Detection ─────────────────────────────────────────────

/// Configuration for a deterministic anomaly detection rule.
/// Rules are seeded or admin-configured; AI may explain but not override severity.
/// Added: Phase 21 Sprint 21.4
model AnomalyRule {
  id              String   @id @default(cuid())
  /// Unique key for this rule (e.g. "docs.duplicate_numbering")
  key             String   @unique
  /// Category aligns with IntelInsightCategory
  category        String
  /// DEFAULT severity when this rule fires (CRITICAL | HIGH | MEDIUM | LOW | INFO)
  severityDefault String
  enabled         Boolean  @default(true)
  /// JSON: thresholds, time windows, plan gate, etc.
  thresholdConfig Json?
  /// Optional plan gate key (null = available to all)
  planGate        String?
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category, enabled])
  @@map("anomaly_rule")
}

/// Tracks a single anomaly detection sweep for an org.
/// Written at the start and end of each detection run.
/// Added: Phase 21 Sprint 21.4
model AnomalyDetectionRun {
  id              String    @id @default(cuid())
  orgId           String
  status          String    @default("RUNNING")
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  rulesEvaluated  Int       @default(0)
  insightsCreated Int       @default(0)
  insightsUpdated Int       @default(0)
  errorMessage    String?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, startedAt])
  @@map("anomaly_detection_run")
}

// ─── Phase 21: AI Governance ──────────────────────────────────────────────────

/// Per-call AI usage metering record.
