  @@map("insight_event")
}

enum AiJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

/// Governs a single AI provider call or rule evaluation.
/// Captures prompt template version, model, token usage, and output reference.
/// Added: Phase 21 Sprint 21.1
model AiJob {
  id                    String      @id @default(cuid())
