  createdAt     DateTime    @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
  @@index([actorId, status])
  @@map("proxy_grant")
}

model AuditLog {
  id            String      @id @default(cuid())
  orgId         String
  actorId       String      @db.Uuid
  representedId String?     @db.Uuid
  proxyGrantId  String?
  action        String
  entityType    String?
  entityId      String?
  metadata      Json?
  ipAddress     String?
  userAgent     String?
