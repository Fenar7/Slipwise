generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── User Profile (linked to Supabase auth.users via UUID) ───────────────────

model Profile {
  id        String   @id @db.Uuid // matches auth.users.id
  name      String
  email     String   @unique
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Phase 24.5: TOTP 2FA
  totpSecret         String? // AES-256-CBC encrypted TOTP secret
  totpEnabled        Boolean   @default(false)
  totpEnabledAt      DateTime?
  recoveryCodes      Json? // array of bcrypt-hashed 8 recovery codes
  twoFaEnforcedByOrg Boolean   @default(false)

  // Phase 38: Passkey MFA
  passkeyEnabled    Boolean   @default(false)
  passkeyEnabledAt  DateTime?
  preferredMfaMethod String   @default("passkey") // passkey | totp

  members              Member[]
  passkeys             PasskeyCredential[]
  auditActorLogs       AuditLog[]            @relation("AuditActor")
  auditRepLogs         AuditLog[]            @relation("AuditRepresented")
  referrals            Referral[]
  onboardingProgress   OnboardingProgress?
  pushSubscriptions    PushSubscription[]
  orgPreferences       UserOrgPreference[]
  quotes               Quote[]
  arrangements         PaymentArrangement[]
  oauthAuthorizations  OAuthAuthorization[]
  flashReportSchedules FlashReportSchedule[]
  sequenceSnapshots    SequenceSnapshot[]

  @@map("profiles")
}

// ─── Phase 38: Passkey Credentials ────────────────────────────────────────────

model PasskeyCredential {
  id             String   @id @default(cuid())
  userId         String   @db.Uuid
  credentialId   String   @unique
  publicKey      Bytes
  counter        BigInt   @default(0)
  transports     String[] @default([])
  deviceName     String?
  deviceType     String?
  backedUp       Boolean  @default(false)
  lastUsedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("passkey_credentials")
}

// ─── Phase 38: WebAuthn Challenge Store ───────────────────────────────────────

model WebAuthnChallenge {
  id        String   @id @default(cuid())
  userId    String   @db.Uuid
  purpose   String // "registration" | "authentication"
  challenge String
  consumed  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId, purpose, consumed])
  @@index([expiresAt])
  @@map("webauthn_challenges")
}

// ─── Organization ─────────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  createdAt DateTime @default(now())
  metadata  String?

  members                      Member[]
  invitations                  Invitation[]
  branding                     BrandingProfile?
  defaults                     OrgDefaults?
  customers                    Customer[]
  vendors                      Vendor[]
  employees                    Employee[]
  invoices                     Invoice[]
  vouchers                     Voucher[]
  sequences                    Sequence[]
  sequenceSnapshots            SequenceSnapshot[]
  salarySlips                  SalarySlip[]
  salaryPresets                SalaryPreset[]
  attachments                  FileAttachment[]
  reportSnapshots              ReportSnapshot[]
  glAccounts                   GlAccount[]
  fiscalPeriods                FiscalPeriod[]
  journalEntries               JournalEntry[]
  journalLines                 JournalLine[]
  bankAccounts                 BankAccount[]
  bankStatementImports         BankStatementImport[]
  bankTransactions             BankTransaction[]
  bankTransactionMatches       BankTransactionMatch[]
  vendorBills                  VendorBill[]
  vendorBillPayments           VendorBillPayment[]
  paymentRuns                  PaymentRun[]
  closeRuns                    CloseRun[]
  closeTasks                   CloseTask[]
  proxyGrants                  ProxyGrant[]
  auditLogs                    AuditLog[]
  auditChainVerifications      AuditChainVerification[]
  auditPackageExports          AuditPackageExport[]
  paymentOptimizationRuns      PaymentOptimizationRun[]
  cashFlowAlertConfig          CashFlowAlertConfig?
  flashReportSchedules         FlashReportSchedule[]
  flashReportDeliveries        FlashReportDelivery[]
  executiveKpiCaches           ExecutiveKpiCache[]
  subscription                 Subscription?
  usageRecords                 UsageRecord[]
  storageUsage                 StorageUsage[]
  sendLogs                     SendLog[]
  sharedDocuments              SharedDocument[]
  virtualAccounts              CustomerVirtualAccount[]
  unmatchedPayments            UnmatchedPayment[]
  billingInvoices              BillingInvoice[]
  apiKeys                      ApiKey[]
  webhookEndpoints             ApiWebhookEndpoint[]
  apiRequestLogs               ApiRequestLog[]
  ssoConfig                    SsoConfig?
  orgPreferences               UserOrgPreference[]
  orgDomain                    OrgDomain?
  whiteLabel                   OrgWhiteLabel?
  emailDomains                 OrgEmailDomain[]
  ocrJobs                      OcrJob[]
  integrations                 OrgIntegration[]
  dunningSequences             DunningSequence[]
  dunningLogs                  DunningLog[]
  dunningOptOuts               DunningOptOut[]
  portalTokens                 CustomerPortalToken[]
  portalAccessLogs             CustomerPortalAccessLog[]
  portalSessions               CustomerPortalSession[]
  statements                   CustomerStatement[]
  quotes                       Quote[]
  arrangements                 PaymentArrangement[]
  tdsRecords                   TdsRecord[]
  marketplaceTemplates         MarketplaceTemplate[]
  marketplacePurchases         MarketplacePurchase[]
  marketplacePayoutBeneficiary MarketplacePayoutBeneficiary?
  marketplacePayoutItems       MarketplacePayoutItem[]
  marketplacePayoutEvents      MarketplacePayoutEvent[]
  approvalPolicies             ApprovalPolicy[]
  approvalDelegations          ApprovalDelegation[]
  ticketSlaPolicies            TicketSlaPolicy[]
  ticketEscalationRules        TicketEscalationRule[]
  scheduledActions             ScheduledAction[]
  deadLetterActions            DeadLetterAction[]
  workflowDefinitions          WorkflowDefinition[]
  workflowRuns                 WorkflowRun[]
  marketplaceReviews           MarketplaceReview[]
  marketplaceRevenue           MarketplaceRevenue[]
  oauthApps                    OAuthApp[]
  oauthAuthorizations          OAuthAuthorization[]
  partnerProfile               PartnerProfile?
  partnerManagedOrgs           PartnerManagedOrg[]
  partnerAccessRequests        PartnerClientAccessRequest[]  @relation("ClientOrgAccessRequests")
  documentIndexes              DocumentIndex[]
  documentEvents               DocumentEvent[]
  ssoBreakGlassCodes           SsoBreakGlassCode[]
  ssoAuthnRequests             SsoAuthnRequest[]
  ssoAssertionReplays          SsoAssertionReplay[]
  gstFilingRuns                GstFilingRun[]
  gstFilingIssues              GstFilingValidationIssue[]
  gstFilingSubmissions         GstFilingSubmission[]
  gstFilingReconciliations     GstFilingReconciliation[]
  gstFilingEvents              GstFilingEvent[]
  // Phase 21: SW Intel
  intelInsights                IntelInsight[]
  aiJobs                       AiJob[]
  extractionReviews            ExtractionReview[]
  customerHealthSnapshots      CustomerHealthSnapshot[]
  anomalyDetectionRuns         AnomalyDetectionRun[]
  aiUsageRecords               AiUsageRecord[]
  // Phase 22: Share Center
  shareBundles                 ShareBundle[]
  shareAccessLogs              ShareAccessLog[]
  // Phase 22: Portal Analytics
  externalAccessEvents         ExternalAccessEvent[]
  // Phase 23: SW Pixel + Usage Metering
  pixelJobRecords              PixelJobRecord[]
  usageEvents                  UsageEvent[]
  orgUsageSnapshots            OrgUsageSnapshot[]
  // Phase 25: Integration Hub + Payroll
  tallyImportLogs              TallyImportLog[]
  payrollRuns                  PayrollRun[]
  payrollSettings              PayrollSettings?
  // Phase 26: Inventory & Procurement
  inventoryItems               InventoryItem[]
  warehouses                   Warehouse[]
  stockLevels                  StockLevel[]
  stockEvents                  StockEvent[]
  stockAdjustments             StockAdjustment[]
  stockTransfers               StockTransfer[]
  purchaseOrders               PurchaseOrder[]
  goodsReceiptNotes            GoodsReceiptNote[]
  threeWayMatchResults         ThreeWayMatchResult[]
  // Phase 26: Multi-Entity
  entityGroupId                String?                       @map("entity_group_id")
  parentOrgId                  String?                       @map("parent_org_id")
  entityType                   EntityType                    @default(STANDALONE) @map("entity_type")
  consolidationCurrency        String                        @default("INR") @map("consolidation_currency")
  entityGroup                  EntityGroup?                  @relation("GroupMembers", fields: [entityGroupId], references: [id])
  parentOrg                    Organization?                 @relation("ParentChild", fields: [parentOrgId], references: [id])
  childOrgs                    Organization[]                @relation("ParentChild")
  adminEntityGroup             EntityGroup?                  @relation("GroupAdmin")
  sourceTransfers              InterCompanyTransfer[]        @relation("ICTSource")
  destinationTransfers         InterCompanyTransfer[]        @relation("ICTDestination")
  // Sprint 26.4: Compliance
  gstr2bImports                Gstr2bImport[]
  eInvoiceRequests             EInvoiceRequest[]
  eInvoiceConfig               EInvoiceConfig?
  // Sprint 26.5: CRM & SOP
  crmNotes                     CrmNote[]
  sopDocuments                 SopDocument[]
  // Phase 29: Tagging Platform
  documentTags                 DocumentTag[]
  // Phase 27: Forecast & Tax
  forecastSnapshots            ForecastSnapshot[]
  taxConfigs                   TaxConfig[]
  taxLiabilityEstimates        TaxLiabilityEstimate[]
  primaryTaxRegion             TaxRegion?                    @map("primary_tax_region")
  // Phase 28: Billing & Subscription
  billingAccount               BillingAccount?
  billingDunningAttempts       BillingDunningAttempt[]
  // Phase 28: Governance & Platform
  customRoles                  CustomRole[]
  dataResidencyConfig          DataResidencyConfig?
  webhookDeadLetters           WebhookDeadLetter[]

  @@index([entityGroupId])
  @@map("organization")
}

model Member {
  id             String   @id @default(cuid())
  organizationId String
  userId         String   @db.Uuid
  role           String   @default("member")
  customRoleId   String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         Profile      @relation(fields: [userId], references: [id], onDelete: Cascade)
  customRole   CustomRole?  @relation(fields: [customRoleId], references: [id], onDelete: SetNull)

  @@unique([organizationId, userId])
  @@index([customRoleId])
  @@map("member")
}

model Invitation {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  role           String?
  status         String   @default("pending")
  expiresAt      DateTime
  inviterId      String   @db.Uuid

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("invitation")
}

// ─── Custom domain models ──────────────────────────────────────────────────────

model BrandingProfile {
  id             String   @id @default(cuid())
  organizationId String   @unique
  logoUrl        String?
  accentColor    String   @default("#dc2626")
  fontFamily     String   @default("Inter")
  fontColor      String   @default("#1a1a1a")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("branding_profile")
}

model OrgDefaults {
  id             String @id @default(cuid())
  organizationId String @unique

  bankName        String?
  bankAccount     String?
  bankIFSC        String?
  taxId           String?
  gstin           String?
  businessAddress String?

  invoicePrefix     String @default("INV")
  invoiceCounter    Int    @default(1)
  voucherPrefix     String @default("VCH")
  voucherCounter    Int    @default(1)
  salarySlipPrefix  String @default("SAL")
  salarySlipCounter Int    @default(1)
  vendorBillPrefix  String @default("BILL")
  vendorBillCounter Int    @default(1)

  defaultInvoiceTemplate String @default("minimal")
  defaultVoucherTemplate String @default("minimal-office")
  defaultSlipTemplate    String @default("modern-premium")

  upiVpa       String?
  gstStateCode String?
  panNumber    String?

  // Phase 14: Portal
  portalEnabled       Boolean @default(false)
  portalHeaderMessage String?
  portalSupportEmail  String?
  portalSupportPhone  String?

  // Phase 22: Portal policies
  portalMagicLinkExpiryHours   Int     @default(24)
  portalSessionExpiryHours     Int     @default(24)
  portalProofUploadEnabled     Boolean @default(false)
  portalTicketCreationEnabled  Boolean @default(true)
  portalStatementEnabled       Boolean @default(true)
  portalQuoteAcceptanceEnabled Boolean @default(false)

  // Phase 24.5: High-value payment approval gate
  highValuePaymentThreshold  Float   @default(100000)
  requireDualApprovalPayment Boolean @default(false)
  // Phase 14: Quotes
  quotePrefix                String  @default("QTE")
  quoteCounter               Int     @default(1)
  quoteValidityDays          Int     @default(14)
  quoteHeaderLabel           String  @default("QUOTE")
  // Phase 14: Dunning
  defaultDunningSeqId        String?

  // Phase 15.2: i18n + Country
  defaultLanguage    String   @default("en")
  defaultDocLanguage String   @default("en")
  country            String   @default("IN")
  baseCurrency       String   @default("INR")
  timezone           String   @default("Asia/Kolkata")
  vatRegNumber       String?
  vatRate            Decimal? @db.Decimal(5, 2)
  fiscalYearStart    Int      @default(4)

  // Phase 16: SW Books
  booksEnabled                    Boolean   @default(false)
  coaTemplate                     String?
  coaSeededAt                     DateTime?
  defaultReceivableAccountId      String?
  defaultPayableAccountId         String?
  defaultBankAccountId            String?
  defaultRevenueAccountId         String?
  defaultExpenseAccountId         String?
  defaultPayrollExpenseAccountId  String?
  defaultPayrollPayableAccountId  String?
  defaultGstOutputAccountId       String?
  defaultTdsPayableAccountId      String?
  defaultGatewayClearingAccountId String?
  defaultSuspenseAccountId        String?

  // Phase 26.2: Procurement numbering
  poPrefix   String @default("PO")
  poCounter  Int    @default(1)
  grnPrefix  String @default("GRN")
  grnCounter Int    @default(1)

  // Phase 26.3: 3-Way Match tolerances
  matchQtyTolerancePct    Float @default(5.0)
  matchAmountTolerancePct Float @default(2.0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("org_defaults")
}

// ─── Phase 1: Document Sequencing Platform ────────────────────────────────────

enum SequenceDocumentType {
  INVOICE
  VOUCHER
}

enum SequencePeriodicity {
  NONE
  MONTHLY
  YEARLY
  FINANCIAL_YEAR
}

enum SequencePeriodStatus {
  OPEN
  CLOSED
}

enum SequenceChangeType {
  CREATED
  UPDATED
  DEACTIVATED
  REACTIVATED
}

model Sequence {
  id             String               @id @default(cuid())
  organizationId String
  name           String
  documentType   SequenceDocumentType
  periodicity    SequencePeriodicity  @default(NONE)
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  formats      SequenceFormat[]
  periods      SequencePeriod[]
  snapshots    SequenceSnapshot[]
  invoices     Invoice[]          @relation("InvoiceSequence")
  vouchers     Voucher[]          @relation("VoucherSequence")

  @@index([organizationId, documentType])
  @@index([organizationId, isActive])
  @@map("sequence")
}

model SequenceFormat {
  id             String  @id @default(cuid())
  sequenceId     String
  formatString   String
  startCounter   Int     @default(1)
  counterPadding Int     @default(5)
  isDefault      Boolean @default(false)
  createdAt      DateTime @default(now())

  sequence Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([sequenceId])
  @@map("sequence_format")
}

model SequencePeriod {
  id            String               @id @default(cuid())
  sequenceId    String
  startDate     DateTime             @db.Date
  endDate       DateTime             @db.Date
  currentCounter Int                 @default(1)
  status        SequencePeriodStatus @default(OPEN)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  sequence Sequence  @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  invoices Invoice[] @relation("InvoiceSequencePeriod")
  vouchers Voucher[] @relation("VoucherSequencePeriod")

  @@unique([sequenceId, startDate, endDate])
  @@index([sequenceId, status])
  @@map("sequence_period")
}

model SequenceSnapshot {
  id              String              @id @default(cuid())
  organizationId  String
  sequenceId      String
  version         Int

  name            String
  documentType    SequenceDocumentType
  periodicity     SequencePeriodicity
  isActive        Boolean

  formatString    String
  startCounter    Int
  counterPadding  Int
  totalConsumed   Int                 @default(0)

  periodsSnapshot Json

  changeType      SequenceChangeType
  changeSummary   String?
  changedById     String   @db.Uuid
  changeNote      String?

  createdAt       DateTime            @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sequence     Sequence     @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  changedBy    Profile      @relation(fields: [changedById], references: [id])

  @@unique([sequenceId, version])
  @@index([organizationId, documentType])
  @@index([sequenceId, createdAt(sort: Desc)])
  @@map("sequence_snapshot")
}

// ─── Phase 16: SW Books — Accounting Foundation ────────────────────────────────

enum GlAccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
  CONTRA
}

enum NormalBalance {
  DEBIT
  CREDIT
}

enum AccountingStatus {
  PENDING
  POSTED
  REVERSED
}

enum RevenueRecognitionStatus {
  PENDING
  RECOGNIZED
  DEFERRED
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  REVERSED
}

enum JournalSource {
  MANUAL
  INVOICE
  INVOICE_PAYMENT
  VOUCHER
  VENDOR_BILL
  VENDOR_BILL_PAYMENT
  SALARY_SLIP
  GST
  TDS
  BANK_RECONCILIATION
  OPENING_BALANCE
  SYSTEM_REVERSAL
}

enum FiscalPeriodStatus {
  OPEN
  LOCKED
  CLOSED
}

enum BankAccountType {
  BANK
  CASH
  PETTY_CASH
  GATEWAY_CLEARING
}

enum BankImportStatus {
  UPLOADED
  PROCESSING
  PROCESSED
  FAILED
}

enum BankTxnDirection {
  CREDIT
  DEBIT
}

enum BankTxnStatus {
  UNMATCHED
  SUGGESTED
  PARTIALLY_MATCHED
  MATCHED
  IGNORED
}

enum MatchEntityType {
  INVOICE_PAYMENT
  VENDOR_BILL_PAYMENT
  VOUCHER
  JOURNAL_ENTRY
  INTERNAL_TRANSFER
  BANK_FEE
}

model GlAccount {
  id                 String        @id @default(cuid())
  orgId              String
  code               String
  name               String
  accountType        GlAccountType
  normalBalance      NormalBalance
  parentId           String?
  description        String?
  systemKey          String?
  isSystem           Boolean       @default(false)
  isProtected        Boolean       @default(false)
  allowManualEntries Boolean       @default(true)
  isActive           Boolean       @default(true)
  sortOrder          Int           @default(0)
  archivedAt         DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  organization                Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parent                      GlAccount?    @relation("GlAccountHierarchy", fields: [parentId], references: [id])
  children                    GlAccount[]   @relation("GlAccountHierarchy")
  journalLines                JournalLine[]
  bankAccounts                BankAccount[] @relation("BankAccountLedger")
  gatewayClearingBankAccounts BankAccount[] @relation("BankAccountGatewayClearing")
  vendorBills                 VendorBill[]  @relation("VendorBillExpenseAccount")

  @@unique([orgId, code])
  @@unique([orgId, systemKey])
  @@index([orgId, accountType, isActive])
  @@index([orgId, parentId])
  @@map("gl_account")
}

model FiscalPeriod {
  id                 String             @id @default(cuid())
  orgId              String
  label              String
  startDate          DateTime
  endDate            DateTime
  status             FiscalPeriodStatus @default(OPEN)
  isAdjustmentPeriod Boolean            @default(false)
  lockedAt           DateTime?
  lockedBy           String?            @db.Uuid
  reopenReason       String?
  reopenedAt         DateTime?
  reopenedBy         String?            @db.Uuid
  closedAt           DateTime?
  closedBy           String?            @db.Uuid
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  organization   Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  journalEntries JournalEntry[]
  closeRuns      CloseRun[]

  @@unique([orgId, label])
  @@unique([orgId, startDate, endDate])
  @@index([orgId, status, startDate])
  @@map("fiscal_period")
}

model JournalEntry {
  id             String             @id @default(cuid())
  orgId          String
  fiscalPeriodId String
  entryNumber    String
  entryDate      DateTime
  source         JournalSource
  status         JournalEntryStatus @default(DRAFT)
  memo           String?
  sourceId       String?
  sourceRef      String?
  currency       String             @default("INR")
  totalDebit     Decimal            @default(0) @db.Decimal(18, 2)
  totalCredit    Decimal            @default(0) @db.Decimal(18, 2)
  isAdjustment   Boolean            @default(false)
  isReversal     Boolean            @default(false)
  reversalOfId   String?
  metadata       Json?
  createdBy      String?            @db.Uuid
  postedBy       String?            @db.Uuid
  postedAt       DateTime?
  reversedAt     DateTime?
  reversedBy     String?            @db.Uuid
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization            Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  fiscalPeriod            FiscalPeriod       @relation(fields: [fiscalPeriodId], references: [id], onDelete: Restrict)
  reversalOf              JournalEntry?      @relation("JournalReversal", fields: [reversalOfId], references: [id])
  reversals               JournalEntry[]     @relation("JournalReversal")
  lines                   JournalLine[]
  invoicePosted           Invoice?           @relation("InvoicePostedJournal")
  invoicePaymentPosted    InvoicePayment?    @relation("InvoicePaymentJournal")
  voucherPosted           Voucher?           @relation("VoucherPostedJournal")
  vendorBillPosted        VendorBill?        @relation("VendorBillJournal")
  vendorBillPaymentPosted VendorBillPayment? @relation("VendorBillPaymentJournal")
  salarySlipAccrual       SalarySlip?        @relation("SalarySlipJournal")
  salarySlipPayout        SalarySlip?        @relation("SalarySlipPayoutJournal")
  bankAccountOpening      BankAccount?       @relation("BankAccountOpeningJournal")
  stockAdjustmentPosted   StockAdjustment?   @relation("StockAdjJournal")

  @@unique([orgId, entryNumber])
  @@index([orgId, entryDate, status])
  @@index([orgId, source, sourceId])
  @@index([fiscalPeriodId, status])
  @@map("journal_entry")
}

model JournalLine {
  id                String   @id @default(cuid())
  journalEntryId    String
  orgId             String
  accountId         String
  bankTransactionId String?
  lineNumber        Int
  description       String?
  debit             Decimal  @default(0) @db.Decimal(18, 2)
  credit            Decimal  @default(0) @db.Decimal(18, 2)
  entityType        String?
  entityId          String?
  createdAt         DateTime @default(now())

  organization    Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  journalEntry    JournalEntry     @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account         GlAccount        @relation(fields: [accountId], references: [id], onDelete: Restrict)
  bankTransaction BankTransaction? @relation(fields: [bankTransactionId], references: [id], onDelete: SetNull)

  @@unique([journalEntryId, lineNumber])
  @@index([orgId, accountId])
  @@index([orgId, bankTransactionId])
  @@index([orgId, entityType, entityId])
  @@map("journal_line")
}

model BankAccount {
  id                       String          @id @default(cuid())
  orgId                    String
  glAccountId              String          @unique
  openingJournalEntryId    String?         @unique
  gatewayClearingAccountId String?
  type                     BankAccountType @default(BANK)
  name                     String
  bankName                 String?
  maskedAccountNo          String?
  ifscOrSwift              String?
  currency                 String          @default("INR")
  openingBalance           Decimal         @default(0) @db.Decimal(18, 2)
  openingBalanceDate       DateTime?
  mappingProfile           Json?
  isPrimary                Boolean         @default(false)
  isActive                 Boolean         @default(true)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  organization           Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  glAccount              GlAccount             @relation("BankAccountLedger", fields: [glAccountId], references: [id], onDelete: Restrict)
  openingJournalEntry    JournalEntry?         @relation("BankAccountOpeningJournal", fields: [openingJournalEntryId], references: [id], onDelete: SetNull)
  gatewayClearingAccount GlAccount?            @relation("BankAccountGatewayClearing", fields: [gatewayClearingAccountId], references: [id], onDelete: SetNull)
  statementImports       BankStatementImport[]
  transactions           BankTransaction[]

  @@index([orgId, isActive])
  @@index([orgId, isPrimary])
  @@map("bank_account")
}

model BankStatementImport {
  id               String           @id @default(cuid())
  orgId            String
  bankAccountId    String
  fileName         String
  storageKey       String
  checksum         String
  sourceFormat     String           @default("csv")
  status           BankImportStatus @default(UPLOADED)
  mappingProfile   Json?
  importedRows     Int              @default(0)
  failedRows       Int              @default(0)
  errorRows        Json?
  statementStart   DateTime?
  statementEnd     DateTime?
  uploadedByUserId String?          @db.Uuid
  createdAt        DateTime         @default(now())
  completedAt      DateTime?

  organization Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
