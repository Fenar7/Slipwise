// ─── Phase 27.5: Executive Intel Hub ──────────────────────────────────────────

enum FlashReportChannel {
  PUSH
  EMAIL
  WHATSAPP
}

enum FlashReportFrequency {
  DAILY_9AM
  WEEKLY_MONDAY
  MONTHLY_1ST
  CUSTOM_CRON
}

enum FlashDeliveryStatus {
  DELIVERED
  FAILED
  PENDING
}

model FlashReportSchedule {
