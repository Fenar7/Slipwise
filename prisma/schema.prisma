  userId                String?     @db.Uuid
  /// "insight_analysis" | "document_extraction" | "customer_health" | "collection_recommendation"
  feature               String
  status                AiJobStatus @default(QUEUED)
  provider              String?
  model                 String?
  promptTemplateKey     String?
  promptTemplateVersion String?
  inputRef              Json?
  outputRef             Json?
