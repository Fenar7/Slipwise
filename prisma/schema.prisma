model BankTransaction {
  id              String           @id @default(cuid())
  orgId           String
  bankAccountId   String
  importId        String
  txnDate         DateTime
  valueDate       DateTime?
  direction       BankTxnDirection
  amount          Decimal          @db.Decimal(18, 2)
