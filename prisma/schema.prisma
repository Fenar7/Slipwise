model MarketplaceRevenue {
  id              String    @id @default(cuid())
  purchaseId      String    @unique
  publisherOrgId  String
  totalAmount     Decimal   @db.Decimal(8, 2)
  publisherShare  Decimal   @db.Decimal(8, 2)
