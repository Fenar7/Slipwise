  /// CREATED | UPDATED | ACKNOWLEDGED | ACTION_STARTED | RESOLVED | DISMISSED | EXPIRED | REOPENED
  eventType  String
  actorId    String?  @db.Uuid
  actorLabel String?
  metadata   Json?
  createdAt  DateTime @default(now())

