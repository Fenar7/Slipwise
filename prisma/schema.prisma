  payoutMethod           String    @default("bank_transfer")
  bankAccountCiphertext  String?
  bankAccountLast4       String?
  bankAccountFingerprint String?
  ifscCiphertext         String?
  upiIdCiphertext        String?
  status                 String    @default("pending_verification")
  providerName           String?
  providerBeneficiaryId  String?
  verificationReference  String?
  verificationNotes      String?
  verifiedAt             DateTime?
  lastChangedAt          DateTime  @default(now())
  createdByUserId        String?   @db.Uuid
  updatedByUserId        String?   @db.Uuid
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  publisherOrg Organization             @relation(fields: [publisherOrgId], references: [id], onDelete: Cascade)
  payoutItems  MarketplacePayoutItem[]
  payoutEvents MarketplacePayoutEvent[]

  @@index([status, updatedAt])
  @@map("marketplace_payout_beneficiary")
}

model MarketplacePayoutRun {
  id                String    @id @default(cuid())
  runNumber         String    @unique
  status            String    @default("draft")
  providerName      String    @default("manual")
  totalAmount       Decimal   @default(0) @db.Decimal(12, 2)
  itemCount         Int       @default(0)
  successCount      Int       @default(0)
  failureCount      Int       @default(0)
  manualReviewCount Int       @default(0)
  notes             String?
  requestedByUserId String?   @db.Uuid
  approvedByUserId  String?   @db.Uuid
  approvedAt        DateTime?
  executedByUserId  String?   @db.Uuid
  executedAt        DateTime?
  completedAt       DateTime?
  failedAt          DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  items    MarketplacePayoutItem[]
  attempts MarketplacePayoutAttempt[]
  events   MarketplacePayoutEvent[]

  @@index([status, createdAt])
  @@map("marketplace_payout_run")
}

model MarketplacePayoutItem {
  id                  String    @id @default(cuid())
  payoutRunId         String
  revenueId           String    @unique
  publisherOrgId      String
  beneficiaryId       String
  amount              Decimal   @db.Decimal(12, 2)
  status              String    @default("pending")
  providerReferenceId String?
  externalReferenceId String?
  failureCode         String?
  failureMessage      String?
  manualReviewReason  String?
  lastAttemptAt       DateTime?
  settledAt           DateTime?
  attemptCount        Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  payoutRun    MarketplacePayoutRun         @relation(fields: [payoutRunId], references: [id], onDelete: Cascade)
  revenue      MarketplaceRevenue           @relation(fields: [revenueId], references: [id], onDelete: Restrict)
  publisherOrg Organization                 @relation(fields: [publisherOrgId], references: [id], onDelete: Cascade)
  beneficiary  MarketplacePayoutBeneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Restrict)
  attempts     MarketplacePayoutAttempt[]
  events       MarketplacePayoutEvent[]

  @@unique([payoutRunId, revenueId])
  @@index([publisherOrgId, status])
  @@index([status, createdAt])
  @@map("marketplace_payout_item")
}

model MarketplacePayoutAttempt {
  id                  String    @id @default(cuid())
  payoutRunId         String
  payoutItemId        String
  providerName        String
  status              String    @default("pending")
  idempotencyKey      String    @unique
  providerRequestId   String?
  providerReferenceId String?
  requestPayload      Json
  responsePayload     Json?
  failureCode         String?
  failureMessage      String?
  retryable           Boolean   @default(true)
  processedAt         DateTime?
  createdAt           DateTime  @default(now())

  payoutRun  MarketplacePayoutRun     @relation(fields: [payoutRunId], references: [id], onDelete: Cascade)
  payoutItem MarketplacePayoutItem    @relation(fields: [payoutItemId], references: [id], onDelete: Cascade)
  events     MarketplacePayoutEvent[]

  @@index([payoutItemId, createdAt])
  @@index([status, createdAt])
  @@map("marketplace_payout_attempt")
}

model MarketplacePayoutEvent {
  id              String   @id @default(cuid())
  publisherOrgId  String?
  payoutRunId     String?
  payoutItemId    String?
  payoutAttemptId String?
  revenueId       String?
  beneficiaryId   String?
  actorId         String?  @db.Uuid
  actorType       String   @default("user")
  eventType       String
  fromStatus      String?
  toStatus        String?
  reason          String?
  metadata        Json?
  createdAt       DateTime @default(now())

  publisherOrg  Organization?                 @relation(fields: [publisherOrgId], references: [id], onDelete: Cascade)
  payoutRun     MarketplacePayoutRun?         @relation(fields: [payoutRunId], references: [id], onDelete: Cascade)
  payoutItem    MarketplacePayoutItem?        @relation(fields: [payoutItemId], references: [id], onDelete: Cascade)
  payoutAttempt MarketplacePayoutAttempt?     @relation(fields: [payoutAttemptId], references: [id], onDelete: Cascade)
  revenue       MarketplaceRevenue?           @relation(fields: [revenueId], references: [id], onDelete: Cascade)
  beneficiary   MarketplacePayoutBeneficiary? @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)

  @@index([publisherOrgId, createdAt])
  @@index([eventType, createdAt])
  @@map("marketplace_payout_event")
}

// ─── Sprint 15.3: OAuth ─────────────────────────────────────────────────────

model OAuthApp {
