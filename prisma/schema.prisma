  salarySlip  SalarySlip?  @relation("SalarySlipAttachments", fields: [entityId], references: [id], map: "file_attachment_salary_slip_fkey")
  quote       Quote?       @relation("QuoteAttachments", fields: [entityId], references: [id], map: "file_attachment_quote_fkey")
  ticketReply TicketReply? @relation("TicketReplyAttachments", fields: [entityId], references: [id], map: "file_attachment_ticket_reply_fkey")

  @@index([organizationId, entityType, entityId])
  @@map("file_attachment")
}

model SalaryPreset {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  components     Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("salary_preset")
}

// ─── Phase 4: SW Pay — Invoice Lifecycle ──────────────────────────────────────

model InvoiceStateEvent {
  id         String   @id @default(cuid())
  invoiceId  String
  fromStatus String
  toStatus   String
  actorId    String?  @db.Uuid
  actorName  String?
  reason     String?
  metadata   Json?
  createdAt  DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_state_event")
}

model InvoicePayment {
  id                     String           @id @default(cuid())
  invoiceId              String
  orgId                  String
  amount                 Decimal          @db.Decimal(18, 2)
  currency               String           @default("INR")
  paidAt                 DateTime         @default(now())
  method                 String?
  note                   String?
  isPartial              Boolean          @default(false)
  // Reconciliation fields
  source                 String           @default("admin_manual")
  status                 String           @default("SETTLED")
  externalPaymentId      String?
  externalReferenceId    String?
  externalPayload        Json?
  paymentMethodDisplay   String?
  paymentChannel         String?
  plannedNextPaymentDate String?
  recordedByUserId       String?          @db.Uuid
  reviewedByUserId       String?          @db.Uuid
  reviewedAt             DateTime?
  rejectionReason        String?
  accountingStatus       AccountingStatus @default(PENDING)
  journalEntryId         String?          @unique
  bankMatchId            String?
  clearingAccountId      String?
  accountingPostedAt     DateTime?
  createdAt              DateTime         @default(now())

  invoice      Invoice               @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  proof        InvoiceProof?         @relation("PaymentProof")
  installment  PaymentInstallment?
  journalEntry JournalEntry?         @relation("InvoicePaymentJournal", fields: [journalEntryId], references: [id])
  bankMatch    BankTransactionMatch? @relation("InvoicePaymentBankMatch", fields: [bankMatchId], references: [id])

  @@index([invoiceId])
  @@index([externalPaymentId])
  @@map("invoice_payment")
}

enum ProofReviewStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model InvoiceProof {
  id                     String            @id @default(cuid())
  invoiceId              String
  invoicePaymentId       String?           @unique
  fileUrl                String
  fileName               String
  amount                 Float             @default(0)
  paymentDate            String?
  paymentMethod          String?
  plannedNextPaymentDate String?
  uploadedByToken        String?
  uploadedByUserId       String?           @db.Uuid
  reviewStatus           ProofReviewStatus @default(PENDING)
  reviewNote             String?
  reviewedById           String?           @db.Uuid
  reviewedAt             DateTime?
  createdAt              DateTime          @default(now())

  invoice        Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoicePayment InvoicePayment? @relation("PaymentProof", fields: [invoicePaymentId], references: [id])

  @@index([invoiceId])
  @@map("invoice_proof")
}

model PublicInvoiceToken {
  id             String    @id @default(cuid())
  invoiceId      String
  orgId          String
  token          String    @unique @default(cuid())
  expiresAt      DateTime?
  accessCount    Int       @default(0)
  lastAccessedAt DateTime?
  createdAt      DateTime  @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("public_invoice_token")
}

// ─── Phase 5: SW Flow — Ticketing ─────────────────────────────────────────────

enum TicketCategory {
  BILLING_QUERY
  AMOUNT_DISPUTE
  MISSING_ITEM
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ApprovalPolicyStatus {
  ACTIVE
  INACTIVE
}

enum ApprovalStepMode {
  SINGLE
  SEQUENTIAL
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketSeverity {
  INFORMATIONAL
  BLOCKING
  FINANCE_CRITICAL
  CUSTOMER_ESCALATED
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum WorkflowRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  DEAD_LETTERED
  CANCELLED
}

enum ScheduledActionStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  DEAD_LETTERED
  CANCELLED
}

model InvoiceTicket {
  id                 String         @id @default(cuid())
  invoiceId          String
  orgId              String
  submitterToken     String?
  submitterName      String
  submitterEmail     String
  category           TicketCategory @default(OTHER)
  description        String
  status             TicketStatus   @default(OPEN)
  assigneeId         String?        @db.Uuid
  createdAt          DateTime       @default(now())
  resolvedAt         DateTime?
  priority           TicketPriority @default(NORMAL)
  severity           TicketSeverity @default(INFORMATIONAL)
  dueAt              DateTime?
  firstResponseDueAt DateTime?
  resolutionDueAt    DateTime?
  firstRespondedAt   DateTime?
  breachedAt         DateTime?
  breachType         String?
  escalationLevel    Int            @default(0)
  sourceModule       String?

  invoice Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  replies TicketReply[]

  @@index([invoiceId])
  @@index([orgId, status])
  @@map("invoice_ticket")
}

model TicketReply {
  id               String   @id @default(cuid())
  ticketId         String
  authorId         String?  @db.Uuid
  authorName       String
  portalCustomerId String? // Link to Customer.id if reply is from portal
  isInternal       Boolean  @default(false)
  message          String
  createdAt        DateTime @default(now())

  ticket      InvoiceTicket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  attachments FileAttachment[] @relation("TicketReplyAttachments")

  @@index([ticketId])
  @@index([portalCustomerId])
  @@map("ticket_reply")
}

// ─── Phase 5: SW Flow — Approvals ─────────────────────────────────────────────

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
  EXPIRED
}

model ApprovalPolicy {
  id                String               @id @default(cuid())
  orgId             String
  name              String
  description       String?
  // module/eventType retained for backward compat; entityType unifies doc-type routing
  module            String
  eventType         String
  entityType        String?
  status            ApprovalPolicyStatus @default(ACTIVE)
  stepMode          ApprovalStepMode     @default(SINGLE)
  escalateAfterMins Int?
  // Amount thresholds for threshold-based routing
  minAmount         Decimal?             @db.Decimal(14, 2)
  maxAmount         Decimal?             @db.Decimal(14, 2)
  createdBy         String               @db.Uuid
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  organization Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  rules        ApprovalPolicyRule[]

  @@index([orgId, module, status])
  @@map("approval_policy")
}

model ApprovalPolicyRule {
  id                 String   @id @default(cuid())
  policyId           String
  sequence           Int
  minAmount          Decimal? @db.Decimal(14, 2)
  maxAmount          Decimal? @db.Decimal(14, 2)
  approverRole       String?
  approverUserId     String?  @db.Uuid
  fallbackRole       String?
  fallbackUserId     String?  @db.Uuid
  // Sprint 25.2 extensions
  approverType       String   @default("role") // "role" | "user"
  approvalMode       String   @default("any_one") // "any_one" | "all_required"
  escalateAfterHours Int?
  allowDelegation    Boolean  @default(true)
  createdAt          DateTime @default(now())

  policy ApprovalPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@index([policyId, sequence])
  @@map("approval_policy_rule")
}

model TicketSlaPolicy {
  id                      String   @id @default(cuid())
  orgId                   String
  name                    String
  category                String?
  priority                String?
  firstResponseTargetMins Int
  resolutionTargetMins    Int
  businessHoursOnly       Boolean  @default(false)
  isDefault               Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, isDefault])
  @@map("ticket_sla_policy")
}

model TicketEscalationRule {
  id              String   @id @default(cuid())
  orgId           String
  name            String
  breachType      String
  afterMins       Int
  targetRole      String?
  targetUserId    String?  @db.Uuid
  notifyOrgAdmins Boolean  @default(false)
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, breachType])
  @@map("ticket_escalation_rule")
}

model ScheduledAction {
  id               String                @id @default(cuid())
  orgId            String
  actionType       String
  sourceModule     String
  sourceEntityType String?
  sourceEntityId   String?
  workflowRunId    String?
  payload          Json
  status           ScheduledActionStatus @default(PENDING)
  scheduledAt      DateTime
  attemptCount     Int                   @default(0)
  maxAttempts      Int                   @default(3)
  nextRetryAt      DateTime?
  lastError        String?
  createdAt        DateTime              @default(now())
  completedAt      DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, status, scheduledAt])
  @@index([nextRetryAt, status])
  @@map("scheduled_action")
}

model DeadLetterAction {
  id                String    @id @default(cuid())
  scheduledActionId String    @unique
  orgId             String
  actionType        String
  sourceModule      String
  failureReason     String
  payload           Json
  deadLetteredAt    DateTime  @default(now())
  resolvedAt        DateTime?
  resolvedBy        String?   @db.Uuid

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, deadLetteredAt])
  @@map("dead_letter_action")
}

model WorkflowDefinition {
  id            String         @id @default(cuid())
  orgId         String
  name          String
  description   String?
  triggerType   String
  triggerConfig Json? // trigger-specific configuration (e.g., { daysPastDue: 3 })
  status        WorkflowStatus @default(DRAFT)
  version       Int            @default(1)
  config        Json
  createdBy     String         @db.Uuid
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  organization Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  steps        WorkflowStep[]
  runs         WorkflowRun[]

  @@index([orgId, status])
  @@map("workflow_definition")
}

model WorkflowStep {
  id            String   @id @default(cuid())
  workflowId    String
  sequence      Int
  actionType    String
  config        Json
  conditionJson Json? // optional pre-condition: { field, operator, value }
  label         String? // human-readable step label
  createdAt     DateTime @default(now())

  workflow WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stepRuns WorkflowStepRun[]

  @@index([workflowId, sequence])
  @@map("workflow_step")
}

model WorkflowRun {
  id               String            @id @default(cuid())
  workflowId       String
  orgId            String
  triggerType      String
  sourceModule     String
  sourceEntityType String?
  sourceEntityId   String?
  actorId          String?           @db.Uuid
  status           WorkflowRunStatus @default(PENDING)
  startedAt        DateTime          @default(now())
  completedAt      DateTime?
  failureReason    String?

  workflow     WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  organization Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  stepRuns     WorkflowStepRun[]

  @@index([orgId, status, startedAt])
  @@index([sourceModule, sourceEntityId])
  @@map("workflow_run")
}

model WorkflowStepRun {
  id             String            @id @default(cuid())
  workflowRunId  String
  workflowStepId String
  status         WorkflowRunStatus @default(PENDING)
  attemptCount   Int               @default(0)
  startedAt      DateTime?
  completedAt    DateTime?
  failureReason  String?
  outputPayload  Json?

  workflowRun  WorkflowRun  @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  workflowStep WorkflowStep @relation(fields: [workflowStepId], references: [id], onDelete: Cascade)

  @@index([workflowRunId, status])
  @@map("workflow_step_run")
}

model ApprovalRequest {
  id               String         @id @default(cuid())
  docType          String
  docId            String
  orgId            String
  requestedById    String         @db.Uuid
  requestedByName  String?
  approverId       String?        @db.Uuid
  approverName     String?
  status           ApprovalStatus @default(PENDING)
  note             String?
  createdAt        DateTime       @default(now())
  decidedAt        DateTime?
  policyId         String?
  policyRuleId     String?
  dueAt            DateTime?
  escalatedAt      DateTime?
  escalationLevel  Int            @default(0)
  lastReminderAt   DateTime?
  // Sprint 25.2: chain position tracking
  currentRuleOrder Int            @default(1)

  invoice    Invoice?           @relation("InvoiceApprovals", fields: [docId], references: [id], map: "approval_invoice_fkey")
  voucher    Voucher?           @relation("VoucherApprovals", fields: [docId], references: [id], map: "approval_voucher_fkey")
  vendorBill VendorBill?        @relation("VendorBillApprovals", fields: [docId], references: [id], map: "approval_vendor_bill_fkey")
  paymentRun PaymentRun?        @relation("PaymentRunApprovals", fields: [docId], references: [id], map: "approval_payment_run_fkey")
  salarySlip SalarySlip?        @relation("SalarySlipApprovals", fields: [docId], references: [id], map: "approval_salary_slip_fkey")
  decisions  ApprovalDecision[]

  @@index([orgId, status])
  @@index([docType, docId])
  @@map("approval_request")
}

/// One decision record per approver per chain step, preserving the full decision trail.
model ApprovalDecision {
  id              String   @id @default(cuid())
  requestId       String
  ruleOrder       Int
  decidedById     String   @db.Uuid
  decidedByName   String?
  delegatedFromId String?  @db.Uuid // set if the approver acted via delegation
  decision        String // "APPROVED" | "REJECTED"
  comment         String?
  decidedAt       DateTime @default(now())

  request ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId, ruleOrder])
  @@map("approval_decision")
}

/// Out-of-office delegation: routes approval notifications/decisions from one user to another.
model ApprovalDelegation {
  id         String   @id @default(cuid())
  orgId      String
  fromUserId String   @db.Uuid
  toUserId   String   @db.Uuid
  reason     String?
  validFrom  DateTime
  validUntil DateTime
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, isActive])
  @@index([fromUserId, isActive])
  @@map("approval_delegation")
}

// ─── Phase 5: SW Flow — Notifications ─────────────────────────────────────────

model Notification {
  id             String   @id @default(cuid())
  userId         String   @db.Uuid
  orgId          String
  type           String
  title          String
  body           String
  link           String?
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())
  category       String?
  severity       String?
  sourceModule   String?
  sourceRef      String?
  // Sprint 18.2 delivery extensions
  emailRequested Boolean  @default(false)
  recipientEmail String?

  deliveries NotificationDelivery[]

  @@index([userId, isRead])
  @@index([orgId])
  @@map("notification")
}

// ─── Phase 18 Sprint 18.2: Notification Delivery ─────────────────────────────

enum NotificationDeliveryStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  FAILED
  TERMINAL_FAILURE
  REPLAYED
}

enum NotificationDeliveryChannel {
  in_app
  email
}

model NotificationDelivery {
  id                String                      @id @default(cuid())
  notificationId    String
  orgId             String
  channel           NotificationDeliveryChannel
  recipientTarget   String
  status            NotificationDeliveryStatus  @default(QUEUED)
  attemptCount      Int                         @default(0)
  maxAttempts       Int                         @default(3)
  provider          String?
  providerRef       String?
  sourceModule      String?
  sourceRef         String?
  workflowRunId     String?
  scheduledActionId String?
  queuedAt          DateTime                    @default(now())
  sentAt            DateTime?
  deliveredAt       DateTime?
  failedAt          DateTime?
  nextRetryAt       DateTime?
  failureReason     String?
  replayedFromId    String?
  replayedAt        DateTime?
  replayedBy        String?                     @db.Uuid

  notification Notification           @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  replayedFrom NotificationDelivery?  @relation("DeliveryReplay", fields: [replayedFromId], references: [id], onDelete: SetNull)
  replays      NotificationDelivery[] @relation("DeliveryReplay")

  @@index([orgId, status])
  @@index([orgId, channel])
  @@index([notificationId])
  @@index([nextRetryAt, status])
  @@index([orgId, sourceModule])
  @@map("notification_delivery")
}

// ─── Phase 5: SW Flow — Activity Feed ─────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(cuid())
  orgId     String
  actorId   String?  @db.Uuid
  actorName String
  event     String
  docType   String?
  docId     String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([orgId, createdAt])
  @@map("activity_log")
}

// ─── Phase 5: SW Flow — Scheduled Send ────────────────────────────────────────

enum SendStatus {
  PENDING
  SENT
  FAILED
}

model ScheduledSend {
  id             String     @id @default(cuid())
  invoiceId      String
  orgId          String
  recipientEmail String
  scheduledAt    DateTime
  status         SendStatus @default(PENDING)
  sentAt         DateTime?
  failReason     String?
  createdAt      DateTime   @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
  @@index([scheduledAt, status])
  @@map("scheduled_send")
}

// ─── Phase 5: SW Flow — Recurring Invoice ─────────────────────────────────────

enum RecurringFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum RecurringStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

model RecurringInvoiceRule {
  id            String             @id @default(cuid())
  orgId         String
  baseInvoiceId String             @unique
  frequency     RecurringFrequency @default(MONTHLY)
  nextRunAt     DateTime
  endDate       DateTime?
  autoSend      Boolean            @default(false)
  status        RecurringStatus    @default(ACTIVE)
  runsCount     Int                @default(0)
  lastRunAt     DateTime?
  createdAt     DateTime           @default(now())

  baseInvoice       Invoice   @relation("RecurringBase", fields: [baseInvoiceId], references: [id], onDelete: Cascade)
  generatedInvoices Invoice[] @relation("RecurringGenerated")

  @@index([orgId, status])
  @@index([nextRunAt, status])
  @@map("recurring_invoice_rule")
}

// ─── Phase 5: SW Flow — Job Log ───────────────────────────────────────────────

model JobLog {
  id           String    @id @default(cuid())
  jobName      String
  jobId        String?
  orgId        String?
  status       String    @default("pending")
  invoiceId    String?
  errorMessage String?
  payload      Json?
  retryCount   Int       @default(0)
  maxRetries   Int       @default(3)
  nextRetryAt  DateTime?
  triggeredAt  DateTime  @default(now())
  completedAt  DateTime?
  error        String?

  @@index([jobName, status])
  @@index([orgId, status])
  @@index([nextRetryAt, status])
  @@map("job_log")
}

// ─── Phase 6: SW Intel — Report Snapshots ─────────────────────────────────────

model ReportSnapshot {
  id           String    @id @default(cuid())
  orgId        String
  reportType   String
  filters      Json
  rowCount     Int
  generatedAt  DateTime  @default(now())
  downloadedAt DateTime?
  createdBy    String

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, reportType])
  @@map("report_snapshot")
}

model GstFilingRun {
  id                    String              @id @default(cuid())
  orgId                 String
  periodMonth           String
  returnType            GstFilingReturnType @default(GSTR1)
  status                GstFilingRunStatus  @default(DRAFT)
  sourceSnapshotHash    String?
  validatedSnapshotHash String?
  blockerCount          Int                 @default(0)
  warningCount          Int                 @default(0)
  summary               Json?
  createdByUserId       String?             @db.Uuid
  updatedByUserId       String?             @db.Uuid
  submittedByUserId     String?             @db.Uuid
  submittedAt           DateTime?
  filedAt               DateTime?
  reconciledAt          DateTime?
  lastValidatedAt       DateTime?
  notes                 String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  organization     Organization               @relation(fields: [orgId], references: [id], onDelete: Cascade)
  validationIssues GstFilingValidationIssue[]
  submissions      GstFilingSubmission[]
  reconciliations  GstFilingReconciliation[]
  events           GstFilingEvent[]

  @@unique([orgId, periodMonth, returnType])
  @@index([orgId, status, periodMonth])
  @@map("gst_filing_run")
}

model GstFilingValidationIssue {
  id            String                      @id @default(cuid())
  filingRunId   String
  orgId         String
  code          String
  severity      GstFilingValidationSeverity
  message       String
  invoiceId     String?
  invoiceNumber String?
  metadata      Json?
  createdAt     DateTime                    @default(now())

  filingRun    GstFilingRun @relation(fields: [filingRunId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([filingRunId, severity])
  @@index([orgId, createdAt])
  @@map("gst_filing_validation_issue")
}

model GstFilingSubmission {
  id                    String                    @id @default(cuid())
  filingRunId           String
  orgId                 String
  status                GstFilingSubmissionStatus @default(INTENT_RECORDED)
  provider              GstFilingProvider         @default(MANUAL)
  attempt               Int
  requestHash           String
  externalReference     String?
  acknowledgementNumber String?
  responsePayload       Json?
  errorMessage          String?
  initiatedByUserId     String?                   @db.Uuid
  completedByUserId     String?                   @db.Uuid
  initiatedAt           DateTime                  @default(now())
  completedAt           DateTime?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  filingRun    GstFilingRun @relation(fields: [filingRunId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([filingRunId, attempt])
  @@index([orgId, status, initiatedAt])
  @@map("gst_filing_submission")
}

model GstFilingReconciliation {
  id               String                        @id @default(cuid())
  filingRunId      String
  orgId            String
  status           GstFilingReconciliationStatus @default(PENDING)
  matchedCount     Int                           @default(0)
  varianceCount    Int                           @default(0)
  delta            Json?
  note             String?
  resolvedByUserId String?                       @db.Uuid
  resolvedAt       DateTime?
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt

  filingRun    GstFilingRun @relation(fields: [filingRunId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, status, createdAt])
  @@index([filingRunId, createdAt])
  @@map("gst_filing_reconciliation")
}

model GstFilingEvent {
  id          String             @id @default(cuid())
  filingRunId String
  orgId       String
  eventType   GstFilingEventType
  actorId     String?            @db.Uuid
  note        String?
  metadata    Json?
  createdAt   DateTime           @default(now())

