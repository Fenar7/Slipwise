// ─── Sprint 15.3: Partner ────────────────────────────────────────────────────

enum PartnerType {
  ACCOUNTANT
  TECHNOLOGY
  RESELLER
}

enum PartnerStatus {
  PENDING // legacy — equivalent to APPLIED; retained for backward compat
  UNDER_REVIEW // platform admin has opened the application for review
  APPROVED // partner is active and may manage client orgs
  SUSPENDED // temporarily blocked; managed-client access is revoked
  REVOKED // permanently removed; cannot re-activate
}

enum PartnerAccessRequestStatus {
  PENDING // awaiting client-org admin review
  APPROVED // client approved — creates an active PartnerManagedOrg record
  REJECTED // client declined
  CANCELLED // partner withdrew the request
  EXPIRED // request lapsed without action
}

/// Partner program profile. One per org. Lifecycle: PENDING → UNDER_REVIEW → APPROVED | REVOKED.
/// Approved partners may be SUSPENDED (temporary) or REVOKED (permanent) by platform admins.
/// All status transitions are append-only via PartnerReviewEvent.
/// Added: Phase 20 Sprint 20.4
model PartnerProfile {
  id              String        @id @default(cuid())
  orgId           String        @unique
  type            PartnerType
  companyName     String
  website         String?
  description     String?
  logoUrl         String?
  status          PartnerStatus @default(PENDING)
  partnerCode     String        @unique
  revenueShare    Decimal       @db.Decimal(5, 2)
  managedOrgCount Int           @default(0)

  // Lifecycle audit fields — set by platform-admin review actions
  reviewedByUserId String?
  reviewedAt       DateTime?
  reviewNotes      String?
  suspendedAt      DateTime?
  suspendedReason  String?
  revokedAt        DateTime?
  revokedReason    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org            Organization                 @relation(fields: [orgId], references: [id])
  managedOrgs    PartnerManagedOrg[]
  reviewEvents   PartnerReviewEvent[]
  activityLogs   PartnerActivityLog[]
  accessRequests PartnerClientAccessRequest[]

  @@map("partner_profiles")
}

/// Explicit client-org assignment for an approved partner.
/// scope defines what operations the partner may perform on the client org.
/// All assignments carry actor attribution. Revocation immediately blocks access.
/// Added: Phase 20 Sprint 20.4
model PartnerManagedOrg {
  id            String    @id @default(cuid())
  partnerId     String
  orgId         String
  addedAt       DateTime  @default(now())
  addedByUserId String?
  scope         String[] // e.g. ["view_invoices","manage_documents","view_payments"]
  revokedAt     DateTime?
  revokedBy     String?

  partner      PartnerProfile       @relation(fields: [partnerId], references: [id])
  org          Organization         @relation(fields: [orgId], references: [id])
  activityLogs PartnerActivityLog[]

  @@unique([partnerId, orgId])
  @@map("partner_managed_orgs")
}

/// Client-org access request submitted by an approved partner.
/// The client org admin must explicitly APPROVE before an active PartnerManagedOrg is created.
/// Empty scope is never valid — partners must enumerate specific permissions.
/// Added: Phase 20 Pre-Master Remediation
model PartnerClientAccessRequest {
  id                String                     @id @default(cuid())
  partnerId         String
  clientOrgId       String
  requestedByUserId String
  scope             String[]
  status            PartnerAccessRequestStatus @default(PENDING)
  notes             String?
  reviewedByUserId  String?
  reviewedAt        DateTime?
  expiresAt         DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  partner   PartnerProfile @relation(fields: [partnerId], references: [id])
  clientOrg Organization   @relation("ClientOrgAccessRequests", fields: [clientOrgId], references: [id])

  @@index([partnerId, clientOrgId, status])
  @@map("partner_client_access_requests")
}

/// Append-only audit trail for partner lifecycle state changes.
/// Every approval, rejection, suspension, and revocation creates one record.
/// Added: Phase 20 Sprint 20.4
model PartnerReviewEvent {
  id          String        @id @default(cuid())
  partnerId   String
  actorUserId String
  fromStatus  PartnerStatus
  toStatus    PartnerStatus
  notes       String?
  createdAt   DateTime      @default(now())

  partner PartnerProfile @relation(fields: [partnerId], references: [id])

  @@map("partner_review_events")
}

/// Attribution log for partner actions performed on behalf of client orgs.
/// Every cross-org operation through the partner portal creates one record.
/// Added: Phase 20 Sprint 20.4
model PartnerActivityLog {
  id           String   @id @default(cuid())
  partnerId    String
  actorUserId  String
  managedOrgId String?
  clientOrgId  String?
  action       String
  entityType   String?
  entityId     String?
  metadata     Json?
  createdAt    DateTime @default(now())

  partner    PartnerProfile     @relation(fields: [partnerId], references: [id])
  managedOrg PartnerManagedOrg? @relation(fields: [managedOrgId], references: [id])

  @@map("partner_activity_logs")
}

// ─── Phase 19: SW Docs Control Plane ──────────────────────────────────────────

/// Normalized unified listing and search layer for all document types.
/// Source of truth remains the original document models (Invoice, Voucher,
/// SalarySlip, Quote). This table is the read-optimised vault/listing layer.
/// Added: Phase 19 Sprint 19.1
model DocumentIndex {
  id                String    @id @default(cuid())
  orgId             String
  /// "invoice" | "voucher" | "salary_slip" | "quote"
  docType           String
  documentId        String
  documentNumber    String
  titleOrSummary    String
  counterpartyLabel String?
  status            String
  primaryDate       DateTime
  amount            Float     @default(0)
  currency          String    @default("INR")
  archivedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, docType, documentId])
  @@index([orgId, docType])
  @@index([orgId, status])
  @@index([orgId, archivedAt])
  @@index([orgId, primaryDate])
  @@map("document_index")
}

/// Append-only normalized lifecycle/event history for all document types.
/// Added: Phase 19 Sprint 19.2
model DocumentEvent {
  id         String   @id @default(cuid())
  orgId      String
  /// "invoice" | "voucher" | "salary_slip" | "quote"
  docType    String
  documentId String
  /// e.g. "created" | "updated" | "issued" | "archived" | "restored" |
  ///       "duplicated" | "approved" | "released" | "paid" |
  ///       "quote_accepted" | "quote_declined" | "quote_converted" |
  ///       "sent" | "cancelled"
  eventType  String
  actorId    String?
  actorLabel String?
  eventAt    DateTime @default(now())
  metadata   Json?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, docType, documentId, eventAt])
  @@index([orgId, eventType, eventAt])
  @@index([orgId, docType, eventAt])
  @@map("document_event")
}

// ─── Phase 21: SW Intel Intelligence Foundation ──────────────────────────────

enum IntelInsightStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
  EXPIRED
}

enum IntelInsightSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IntelInsightCategory {
  REVENUE
  RECEIVABLES
  DOCUMENTS
  PAYROLL
  OPERATIONS
  COMPLIANCE
  PARTNER
  MARKETPLACE
  INTEGRATIONS
  SYSTEM
  // Phase 27: Forecast & Tax
  SPENDING_ANOMALY
  FORECAST_DEVIATION
  TAX_LIABILITY
}

enum InsightSourceType {
  RULE
  AI
  HYBRID
  INTEGRATION
  SYSTEM
}

/// Durable insight record shown to org users in the Insights workspace.
/// Status and lifecycle events are append-only via InsightEvent.
/// Added: Phase 21 Sprint 21.1
model IntelInsight {
  id                    String               @id @default(cuid())
  orgId                 String
  category              IntelInsightCategory
  severity              IntelInsightSeverity
  status                IntelInsightStatus   @default(ACTIVE)
  title                 String
  summary               String
  evidence              Json?
  sourceType            InsightSourceType
  sourceRecordType      String?
  sourceRecordId        String?
  recommendedActionType String?
  assignedRole          String?
  createdByJobId        String?
  /// Deduplication key — one active insight per org per key
  dedupeKey             String?
  firstDetectedAt       DateTime             @default(now())
  lastDetectedAt        DateTime             @default(now())
  acknowledgedAt        DateTime?
  acknowledgedByUserId  String?              @db.Uuid
  resolvedAt            DateTime?
  resolvedByUserId      String?              @db.Uuid
  dismissedAt           DateTime?
  dismissedByUserId     String?              @db.Uuid
  dismissedReason       String?
  expiresAt             DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  organization Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  events       InsightEvent[]

  @@unique([orgId, dedupeKey])
  @@index([orgId, status])
  @@index([orgId, category, severity])
  @@index([orgId, status, expiresAt])
  @@map("intel_insight")
}

/// Append-only lifecycle event log for IntelInsight records.
