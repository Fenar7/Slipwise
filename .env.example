# ─── Core App / Supabase ──────────────────────────────────────────────────────
# Get these from your Supabase project dashboard → Settings → API.
# For local dev: run `supabase start` and use the output values.
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── Database ─────────────────────────────────────────────────────────────────
# For local dev, Supabase CLI provides this automatically.
# For production, use the pooled connection as DATABASE_URL and the direct
# connection as DIRECT_URL.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# ─── App URLs / Runtime ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3001"
NEXT_PUBLIC_APP_NAME="Slipwise One"
NODE_ENV="development"

# Platform-provided on Vercel. Leave empty locally unless you need to mimic them.
VERCEL=""
VERCEL_URL=""

# ─── Email / Notifications ────────────────────────────────────────────────────
# App-level transactional mail.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@slipwise.app"

# Supabase Auth email delivery (infrastructure-only, read by supabase/config.toml).
BREVO_SMTP_USER="your-brevo-login@example.com"
BREVO_SMTP_KEY="xkeysib-your-brevo-smtp-key"

# SMS for dunning reminders.
MSG91_API_KEY=""
MSG91_SENDER_ID="SLIPWS"

# Push notifications / web push.
VAPID_SUBJECT="mailto:security@example.com"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# ─── Security / Auth / Background Jobs ────────────────────────────────────────
DUNNING_OPT_OUT_SECRET="replace-with-long-random-secret"
PORTAL_JWT_SECRET="replace-with-long-random-secret"
TOTP_SESSION_SECRET="replace-with-long-random-secret"
CRON_SECRET="replace-with-long-random-secret"
SSO_SESSION_SECRET="replace-with-long-random-secret"
MESSAGING_REALTIME_TOKEN_SECRET="replace-with-long-random-secret-min-32-chars"
# Public WebSocket URL for the messaging realtime gateway.
# Must point to a running gateway instance (e.g., wss://api.example.com/messaging/realtime).
MESSAGING_REALTIME_WS_URL=""
# Optional: port for the standalone messaging realtime server when run directly.
MESSAGING_REALTIME_PORT=8080
# Comma-separated Supabase user IDs allowed to moderate the marketplace.
MARKETPLACE_MODERATOR_USER_IDS=""
# Comma-separated Supabase user IDs allowed to approve/execute marketplace payouts.
MARKETPLACE_FINANCE_USER_IDS=""
# Comma-separated Supabase user IDs with platform admin access (partner governance, global admin surfaces).
PLATFORM_ADMIN_USER_IDS=""
# Payout transport adapter. Keep "manual" until a live provider adapter is deployed.
MARKETPLACE_PAYOUT_PROVIDER="manual"
# Settlement hold window, in days, before completed template revenue becomes payout-eligible.
MARKETPLACE_PAYOUT_SETTLEMENT_HOLD_DAYS="7"
# 32-byte payout beneficiary encryption key encoded as raw text, base64, or hex.
PAYOUT_DETAILS_ENCRYPTION_KEY=""

# Optional custom base URL for customer portal links in emails.
CUSTOMER_PORTAL_BASE_URL=""

# Feature flags. Set FEATURE_SSO_ENABLED="false" to hard-disable enterprise SSO runtime.
FEATURE_PAYMENT_LINKS_ENABLED="true"
FEATURE_SMART_COLLECT_ENABLED="true"
FEATURE_API_PLATFORM_ENABLED="true"
FEATURE_SSO_ENABLED="true"
GST_FILING_PROVIDER="manual"

# ─── Billing / Payments ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
# Plan IDs — run `npx tsx scripts/setup-razorpay-plans.ts` to auto-create
RAZORPAY_PLAN_STARTER_MONTHLY=""
RAZORPAY_PLAN_STARTER_YEARLY=""
RAZORPAY_PLAN_PRO_MONTHLY=""
RAZORPAY_PLAN_PRO_YEARLY=""
RAZORPAY_PLAN_ENTERPRISE_MONTHLY=""
RAZORPAY_PLAN_ENTERPRISE_YEARLY=""

# ─── Storage / Assets ─────────────────────────────────────────────────────────
STORAGE_PROVIDER="supabase"
AWS_REGION="ap-south-1"
AWS_S3_BUCKET_ASSETS=""
AWS_S3_BUCKET_PRIVATE=""
CLOUDFRONT_URL=""

# ─── Redis / Rate Limiting / Cache ────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
REDIS_URL=""

# ─── Observability / Analytics ────────────────────────────────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST=""

# ─── AI / OCR / Browser Export ────────────────────────────────────────────────
OPENAI_API_KEY=""
CHROME_EXECUTABLE_PATH=""
PUPPETEER_EXECUTABLE_PATH=""

# ─── Currency / Exchange Rates ────────────────────────────────────────────────
# `OPEN_EXCHANGE_RATES_APP_ID` is the primary provider used by current code.
# `EXCHANGE_RATE_API_KEY` remains for older compatibility surfaces.
OPEN_EXCHANGE_RATES_APP_ID=""
EXCHANGE_RATE_API_KEY=""
EXCHANGE_RATE_API_URL=""

# ─── India GST / IRP E-Invoicing ──────────────────────────────────────────────
IRP_MODE="sandbox"
IRP_SANDBOX_URL="https://einv-apisandbox.nic.in"
IRP_API_BASE_URL="https://einvoice1.gst.gov.in/eicore/v1.03"
IRP_CLIENT_ID=""
IRP_CLIENT_SECRET=""
IRP_USERNAME=""
IRP_PASSWORD=""

# ─── Accounting Integrations ──────────────────────────────────────────────────
QUICKBOOKS_CLIENT_ID=""
QUICKBOOKS_CLIENT_SECRET=""
QUICKBOOKS_REDIRECT_URI="http://localhost:3001/api/integrations/quickbooks/callback"

ZOHO_CLIENT_ID=""
ZOHO_CLIENT_SECRET=""
ZOHO_REDIRECT_URI="http://localhost:3001/api/integrations/zoho/callback"

# ─── Books / Reconciliation Tunables ──────────────────────────────────────────
# Optional guardrails for bank import and reconciliation matching.
BANK_IMPORT_MAX_ROWS="5000"
BANK_IMPORT_MAX_FILE_SIZE_MB="2"
RECON_MATCH_DATE_WINDOW_DAYS="7"
RECON_MATCH_TOLERANCE_PAISE="1"
